
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funció per verificar si l'usuari és administrador
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Funció per verificar si l'usuari és el propietari de la dada
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Perfils d'empleat: Tots els logats llegeixen (per noms), només owner/admin escriu
    match /employees/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isAdmin();
      
      // Registres de servei: Propietari veu i escriu el seu, admin veu tot
      match /serviceRecords/{recordId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // AUTORITZACIÓ PER QUERIES DE GRUP (collectionGroup)
    match /{path=**}/serviceRecords/{recordId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
    }

    // Clients i Obres: Tots els empleats els poden veure per registrar feina
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Permetem crear obres noves a tots els empleats
    }

    // Documents financers: Admin veu tot, Usuari veu el seu (employeeId)
    match /albarans/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.employeeId == request.auth.uid));
    }
    
    match /invoices/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.employeeId == request.auth.uid));
    }
    
    match /quotes/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.employeeId == request.auth.uid));
    }
    
    match /receipts/{id} {
      allow read: if isAdmin() || (request.auth != null && resource.data.employeeId == request.auth.uid);
      allow write: if isAdmin() || (request.auth != null && (resource == null || resource.data.employeeId == request.auth.uid));
    }
    
    // Comptadors i Backups
    match /counters/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /backups/{id} {
      allow read, write: if isAdmin();
    }
  }
}
