rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra global: permite leitura e escrita em qualquer documento se o utilizador estiver autenticado.
    // Isto resolve problemas de permissão em listagens e filtros (como o aviso de albarans pendentes).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regra explícita para Collection Group (necessária para o Dashboard do Admin buscar todos os serviceRecords)
    match /{path=**}/serviceRecords/{id} {
      allow read, write: if request.auth != null;
    }
  }
}