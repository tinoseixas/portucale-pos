rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regras para Reservas Públicas
    match /restaurant_reservations/{reservationId} {
      allow read: if true; 
      allow create: if request.resource.data.status == 'confirmada';
      allow update, delete: if request.auth != null;
    }

    // Public POS Collections
    match /restaurant_orders/{orderId} {
      allow read, write: if true;
    }
    match /restaurant_loyalty/{phone} {
      allow read, write: if true;
    }

    // Regra padrão para outras coleções (requer autenticação)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
