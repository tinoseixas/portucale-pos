rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para qualquer utilizador autenticado em todas as coleções.
    // Isto garante que não existam erros de "Missing or insufficient permissions".
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}