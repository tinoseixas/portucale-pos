
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para qualquer utilizador autenticado em todas as coleções de topo
    match /employees/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /customers/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /albarans/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /quotes/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /invoices/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /receipts/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /counters/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regra global de fallback para qualquer documento
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regras específicas para consultas de grupo (Collection Groups)
    match /{path=**}/serviceRecords/{id} {
      allow read, write: if request.auth != null;
    }
    match /{path=**}/albarans/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
