rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra global: Permite leitura e escrita em todos os documentos 
    // para qualquer utilizador autenticado.
    // Isto resolve os problemas de permissão ao editar registos de outros utilizadores.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
