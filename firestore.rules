
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para qualquer utilizador autenticado em todas as coleções.
    // Adicionado suporte explícito para consultas de grupo e subcoleções.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regra específica para Collection Groups (necessária para ver todos os serviços de todos os funcionários)
    match /{path=**}/serviceRecords/{id} {
      allow read, write: if request.auth != null;
    }

    match /{path=**}/albarans/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
