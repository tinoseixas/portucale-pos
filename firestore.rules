
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissões globais para utilizadores autenticados.
    // Esta regra simplificada garante acesso total a qualquer utilizador logado para evitar bloqueios de permissão.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
