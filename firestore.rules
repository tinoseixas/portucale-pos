/**
 * @fileoverview Firestore Security Rules for the 'Registre Diari de Treball' application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, with an exception for a designated admin user.
 * Each employee can only access their own data. The admin can read all data for reporting purposes.
 *
 * Data Structure:
 * /employees/{employeeId} - Employee profile data
 * /employees/{employeeId}/serviceRecords/{serviceRecordId} - Service records for an employee
 * /employees/{employeeId}/serviceRecords/{serviceRecordId}/photos/{photoId} - Photos for a service record
 *
 * Key Security Decisions:
 * - A hardcoded admin UID has full read access across all data.
 * - Non-admin users are restricted to their own data via path-based authorization.
 * - Write operations are strictly limited to data owners.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Checks if the request has valid authentication credentials.
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the request is made by the user specified by userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Per identificar l'administrador, si us plau, substitueix 'YOUR_ADMIN_UID_HERE' 
    // amb el teu ID d'usuari real de Firebase.
    function isAdmin() {
        return request.auth.uid == 'tP4c49T8L4cFqCMiPWh85A5i5942';
    }

    // Checks if a document exists and is owned by the user.
    function isExistingOwner(userId) {
      return isOwner(userId) && exists(path(resource.data.id));
    }
    
    // --- Collection Rules ---

    /**
     * @description Protects access to the /employees/{employeeId} collection.
     * Admins can get any profile, users can only get their own.
     */
    match /employees/{employeeId} {
      allow get: if isOwner(employeeId) || isAdmin();
      allow list: if isAdmin(); // Only admin can list all employees
      allow create: if isOwner(employeeId) && request.resource.data.id == employeeId;
      allow update: if isOwner(employeeId);
      allow delete: if isOwner(employeeId);
    }

    /**
     * @description Protects access to the serviceRecords subcollection.
     * Admins can read any service record, users can only access their own.
     */
    match /employees/{employeeId}/serviceRecords/{serviceRecordId} {
      allow get, list: if isOwner(employeeId) || isAdmin();
      allow create: if isOwner(employeeId) && request.resource.data.employeeId == employeeId;
      allow update: if isOwner(employeeId) && request.resource.data.employeeId == resource.data.employeeId;
      allow delete: if isOwner(employeeId);
    }

    /**
     * @description Protects access to the photos subcollection.
     * Admins can read any photo, users can only access their own.
     */
    match /employees/{employeeId}/serviceRecords/{serviceRecordId}/photos/{photoId} {
      allow get, list: if isOwner(employeeId) || isAdmin();
      allow create: if isOwner(employeeId) && request.resource.data.serviceRecordId == serviceRecordId;
      allow update: if isOwner(employeeId) && request.resource.data.serviceRecordId == resource.data.serviceRecordId;
      allow delete: if isOwner(employeeId);
    }
  }
}
