rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão universal para utilizadores autenticados
    // Isto garante que todos os técnicos podem ler e escrever nos seus próprios registos
    // e o admin pode gerir o sistema completo.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Regra específica para permitir consultas de Collection Group (necessário para o Dashboard do Admin)
    match /{path=**}/serviceRecords/{serviceRecord} {
      allow read, write: if request.auth != null;
    }

    // Regras explícitas para as coleções principais para evitar erros de permissão em listagens
    match /albarans/{albaranId} {
      allow read, write: if request.auth != null;
    }
    
    match /invoices/{invoiceId} {
      allow read, write: if request.auth != null;
    }
    
    match /customers/{customerId} {
      allow read, write: if request.auth != null;
    }
    
    match /employees/{employeeId} {
      allow read, write: if request.auth != null;
    }
  }
}
