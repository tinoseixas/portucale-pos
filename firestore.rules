rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura e escrita em qualquer documento se o utilizador estiver autenticado.
    // Esta regra simplificada resolve conflitos de permissões em todas as coleções e grupos.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Suporte explícito para consultas de grupo de coleções (Collection Group)
    match /{path=**}/serviceRecords/{id} {
      allow read, write: if request.auth != null;
    }
  }
}