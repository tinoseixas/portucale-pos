/**
 * @fileoverview Firestore Security Rules for the 'Registre Diari de Treball' application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model, with an exception for a designated admin user.
 * Each employee can only access their own data. The admin can read all data for reporting purposes.
 *
 * Data Structure:
 * /employees/{employeeId} - Employee profile data
 * /employees/{employeeId}/serviceRecords/{serviceRecordId} - Service records for an employee
 *
 * Key Security Decisions:
 * - A hardcoded admin EMAIL has full read access across all data.
 * - Non-admin users are restricted to their own data via path-based authorization.
 * - Write operations are strictly limited to data owners.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    // Checks if the request has valid authentication credentials.
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the request is made by the user specified by userId.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Identifies the administrator by email.
    function isAdmin() {
        return isSignedIn() && request.auth.token.email == 'tino@seixas.com';
    }
    
    // --- Collection Rules ---

    /**
     * @description Protects access to the /employees/{employeeId} collection.
     * Admins can get/list/delete any profile, users can only manage their own.
     */
    match /employees/{employeeId} {
      allow get: if isOwner(employeeId) || isAdmin();
      allow list: if isAdmin(); // Only admin can list all employees
      allow create: if isOwner(employeeId) && request.resource.data.id == employeeId;
      allow update: if isOwner(employeeId) || isAdmin();
      allow delete: if isOwner(employeeId) || isAdmin();

      /**
       * @description Protects access to the serviceRecords subcollection for direct queries.
       * Users can only access their own service records. Admins can access all.
       */
      match /serviceRecords/{serviceRecordId} {
        allow get, list: if isOwner(employeeId) || isAdmin();
        allow create: if isOwner(employeeId) && request.resource.data.employeeId == employeeId;
        allow update: if isOwner(employeeId) || isAdmin();
        allow delete: if isOwner(employeeId) || isAdmin();
      }
    }
    
    // --- Collection Group Rules ---
    
    /**
     * @description Enables admin-only cross-user queries on serviceRecords.
     * This is essential for the administrator dashboard to view all records.
     */
    match /{path=**}/serviceRecords/{serviceRecordId} {
       allow get, list: if isAdmin();
    }
  }
}
