
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissões globais para utilizadores autenticados.
    // Esta regra simplificada garante acesso a qualquer utilizador logado para evitar erros de permissão.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Suporte específico para consultas de grupo (necessário para o resumo de serviços no Dashboard)
    match /{path=**}/serviceRecords/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
