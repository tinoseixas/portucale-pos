
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the employee."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the employee."
        },
        "employeeId": {
          "type": "string",
          "description": "The employee's unique ID. This is to represent the ID in the company."
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "The employee's email address."
        },
        "avatar": {
            "type": "string",
            "format": "uri",
            "description": "URL to the employee's avatar image."
        },
        "phoneNumber": {
            "type": "string",
            "description": "The employee's phone number."
        },
        "role": {
            "type": "string",
            "enum": ["admin", "user"],
            "description": "The role of the user in the system."
        },
        "hourlyRate": {
          "type": "number",
          "description": "The default hourly rate for the employee."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "employeeId"
      ]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "The full name or company name of the customer."
        },
        "address": {
          "type": "string",
          "description": "The physical address of the customer."
        },
        "contact": {
          "type": "string",
          "description": "Primary contact phone number."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The customer's email address."
        },
        "nrt": {
          "type": "string",
          "description": "The tax registration number (NRT/NIF) of the customer."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "ServiceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ServiceRecord",
      "type": "object",
      "description": "Represents a service record for an employee.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the service record."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee. (Relationship: Employee 1:N ServiceRecord)"
        },
        "customerId": {
          "type": "string",
          "description": "Reference to Customer. (Relationship: Customer 1:N ServiceRecord)"
        },
        "customerName": {
            "type": "string",
            "description": "Denormalized customer name for quick display."
        },
        "projectName": {
          "type": "string",
          "description": "Name of the construction project or work site."
        },
        "arrivalDateTime": {
          "type": "string",
          "description": "Date and time of arrival for the service.",
          "format": "date-time"
        },
        "departureDateTime": {
          "type": "string",
          "description": "Date and time of departure for the service.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the service performed."
        },
        "pendingTasks": {
          "type": "string",
          "description": "Description of pending tasks for the service. If this field has text, the record is considered to have pending items."
        },
        "serviceHourlyRate": {
          "type": "number",
          "description": "The specific hourly rate for this service, overriding the employee's default rate."
        },
        "media": {
          "type": "array",
          "description": "Array of media objects (images or videos) as base64 data URLs.",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["image", "video"]
              },
              "dataUrl": {
                "type": "string",
                "format": "uri"
              }
            },
            "required": ["type", "dataUrl"]
          }
        },
        "materials": {
          "type": "array",
          "description": "List of materials used in the service.",
          "items": {
            "type": "object",
            "properties": {
              "description": {
                "type": "string"
              },
              "quantity": {
                "type": "number"
              },
              "unitPrice": {
                "type": "number"
              },
              "imageDataUrl": {
                "type": "string",
                "format": "uri",
                "description": "Data URL of an image for the material."
              }
            }
          }
        },
        "albarans": {
          "type": "array",
          "description": "List of 'albaran' numbers associated with the service record.",
          "items": {
            "type": "string"
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO 8601 timestamp when the service record was last updated."
        }
      },
      "required": [
        "id",
        "employeeId",
        "arrivalDateTime",
        "departureDateTime",
        "description"
      ]
    },
     "Albaran": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Albaran",
      "type": "object",
      "description": "Represents a generated albarà (delivery note/report).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the albarà."
        },
        "albaranNumber": {
          "type": "number",
          "description": "Sequential number for the albarà."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of when the albarà was generated."
        },
        "customerId": {
          "type": "string",
          "description": "ID of the associated customer."
        },
        "customerName": {
          "type": "string",
          "description": "Denormalized name of the customer."
        },
        "projectName": {
          "type": "string",
          "description": "Name of the project/obra."
        },
        "serviceRecordIds": {
          "type": "array",
          "description": "Array of ServiceRecord IDs included in this albarà.",
          "items": { "type": "string" }
        },
        "totalAmount": {
          "type": "number",
          "description": "The total amount calculated for the albarà."
        }
      },
      "required": ["id", "albaranNumber", "createdAt", "projectName", "serviceRecordIds", "totalAmount"]
    },
    "Quote": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Quote",
      "type": "object",
      "description": "Represents a generated quote (pressupost).",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the quote." },
        "quoteNumber": { "type": "number", "description": "Sequential number for the quote." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of when the quote was generated." },
        "customerId": { "type": "string", "description": "ID of the associated customer." },
        "customerName": { "type": "string", "description": "Denormalized name of the customer." },
        "projectName": { "type": "string", "description": "Name of the project/obra." },
        "items": {
          "type": "array",
          "description": "List of items included in the quote.",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "imageDataUrl": { "type": "string", "format": "uri", "description": "Data URL of an image for the item." },
              "discount": { "type": "number", "description": "Percentage discount for the item." }
            },
            "required": ["description", "quantity", "unitPrice"]
          }
        },
        "labor": {
          "type": "object",
          "description": "Labor costs for the quote.",
          "properties": {
            "description": { "type": "string" },
            "cost": { "type": "number" }
          },
          "required": ["description", "cost"]
        },
        "totalAmount": { "type": "number", "description": "The total amount calculated for the quote." }
      },
      "required": ["id", "quoteNumber", "createdAt", "projectName", "items", "labor", "totalAmount"]
    },
    "Invoice": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Invoice",
      "type": "object",
      "description": "Represents a generated invoice (factura).",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the invoice." },
        "invoiceNumber": { "type": "number", "description": "Sequential number for the invoice." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of when the invoice was generated." },
        "customerId": { "type": "string", "description": "ID of the associated customer." },
        "customerName": { "type": "string", "description": "Denormalized name of the customer." },
        "projectName": { "type": "string", "description": "Name of the project/obra." },
        "items": {
          "type": "array",
          "description": "List of items included in the invoice.",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "imageDataUrl": { "type": "string", "format": "uri", "description": "Data URL of an image for the item." },
              "discount": { "type": "number", "description": "Percentage discount for the item." }
            },
            "required": ["description", "quantity", "unitPrice"]
          }
        },
        "labor": {
          "type": "object",
          "description": "Labor costs for the invoice.",
          "properties": {
            "description": { "type": "string" },
            "cost": { "type": "number" }
          },
          "required": ["description", "cost"]
        },
        "totalAmount": { "type": "number", "description": "The total amount calculated for the invoice." },
        "sourceId": { "type": "string", "description": "ID of the albaran or quote it was created from" },
        "sourceType": { "type": "string", "enum": ["albaran", "quote"], "description": "The type of document this invoice was created from." }
      },
      "required": ["id", "invoiceNumber", "createdAt", "projectName", "items", "labor", "totalAmount"]
    },
    "Counter": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Counter",
      "type": "object",
      "description": "A generic counter for sequential numbering.",
      "properties": {
        "lastNumber": {
          "type": "number",
          "description": "The last number that was used."
        }
      },
      "required": ["lastNumber"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": {
            "$ref": "#/backend/entities/Employee"
          },
          "description": "Stores employee profiles. The employeeId is the document ID.  Security rules ensure only the authenticated employee can access their profile.",
          "params": [
            {
              "name": "employeeId",
              "description": "Unique identifier for the employee."
            }
          ]
        }
      },
      {
        "path": "/employees/{employeeId}/serviceRecords/{serviceRecordId}",
        "definition": {
          "entityName": "ServiceRecord",
          "schema": {
            "$ref": "#/backend/entities/ServiceRecord"
          },
          "description": "Stores service records for each employee. Provides path-based authorization. Only the employee who 'owns' the service record can access it.",
          "params": [
            {
              "name": "employeeId",
              "description": "Unique identifier for the employee."
            },
            {
              "name": "serviceRecordId",
              "description": "Unique identifier for the service record."
            }
          ]
        }
      },
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": {
            "$ref": "#/backend/entities/Customer"
          },
          "description": "Stores customer profiles. All authenticated users (employees) can read the list of customers to assign them to service records, but only admins can create, update, or delete customers.",
          "params": [
            {
              "name": "customerId",
              "description": "Unique identifier for the customer."
            }
          ]
        }
      },
      {
        "path": "/albarans/{albaranId}",
        "definition": {
            "entityName": "Albaran",
            "schema": { "$ref": "#/backend/entities/Albaran" },
            "description": "Stores historical records of generated albaràs. All authenticated users can read.",
            "params": [{ "name": "albaranId", "description": "Unique ID for the albarà." }]
        }
      },
       {
        "path": "/quotes/{quoteId}",
        "definition": {
            "entityName": "Quote",
            "schema": { "$ref": "#/backend/entities/Quote" },
            "description": "Stores historical records of generated quotes (pressupostos). All authenticated users can read.",
            "params": [{ "name": "quoteId", "description": "Unique ID for the quote." }]
        }
      },
       {
        "path": "/invoices/{invoiceId}",
        "definition": {
            "entityName": "Invoice",
            "schema": { "$ref": "#/backend/entities/Invoice" },
            "description": "Stores historical records of generated invoices (factures). All authenticated users can read.",
            "params": [{ "name": "invoiceId", "description": "Unique ID for the invoice." }]
        }
      },
      {
        "path": "/counters/albarans",
        "definition": {
            "entityName": "Counter",
            "schema": { "$ref": "#/backend/entities/Counter" },
            "description": "Manages the sequential counter for albarà numbers. Only admins should have write access.",
            "params": []
        }
      },
      {
        "path": "/counters/quotes",
        "definition": {
            "entityName": "Counter",
            "schema": { "$ref": "#/backend/entities/Counter" },
            "description": "Manages the sequential counter for quote numbers. Only admins should have write access.",
            "params": []
        }
      },
       {
        "path": "/counters/invoices",
        "definition": {
            "entityName": "Counter",
            "schema": { "$ref": "#/backend/entities/Counter" },
            "description": "Manages the sequential counter for invoice numbers. Only admins should have write access.",
            "params": []
        }
      }
    ],
    "reasoning": "The Firestore data structure is designed to support the 'Registre Diari de Treball' application, focusing on simplicity, security, and scalability. It leverages path-based ownership for employee data and nested service records. The 'photos' collection has been replaced by a 'media' array within the ServiceRecord document to store base64 data URLs of images and videos directly. This simplifies data retrieval for each service record, as it avoids extra subcollection reads, but may increase document size. This design ensures that security rules can be written clearly and efficiently.\n\n**Authorization Independence and QAPs:**\n\n*   **Employees Collection:** The `/employees/{employeeId}` collection stores employee profiles. Security rules will ensure only the authenticated employee (or an admin) can access their own profile.\n*   **Service Records:** Each employee has a subcollection `/employees/{employeeId}/serviceRecords/{serviceRecordId}`. This structure provides path-based authorization. Only the employee who 'owns' the service record can access it.\n*   **Customers Collection:** The `/customers/{customerId}` collection is readable by all authenticated users to allow assignment, but write access is restricted to admins to maintain data integrity."
  }
}
