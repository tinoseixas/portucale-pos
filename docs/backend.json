
{
  "entities": {
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the employee."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the employee."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the employee."
        },
        "employeeId": {
          "type": "string",
          "description": "The employee's unique ID. This is to represent the ID in the company."
        },
        "email": {
            "type": "string",
            "format": "email",
            "description": "The employee's email address."
        },
        "avatar": {
            "type": "string",
            "format": "uri",
            "description": "URL to the employee's avatar image."
        },
        "phoneNumber": {
            "type": "string",
            "description": "The employee's phone number."
        },
        "role": {
            "type": "string",
            "enum": ["admin", "user"],
            "description": "The role of the user in the system."
        },
        "hourlyRate": {
          "type": "number",
          "description": "The default hourly rate for the employee."
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "employeeId"
      ]
    },
    "Customer": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Customer",
      "type": "object",
      "description": "Represents a customer in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the customer."
        },
        "name": {
          "type": "string",
          "description": "The full name or company name of the customer."
        },
        "street": {
          "type": "string",
          "description": "The street and number."
        },
        "city": {
          "type": "string",
          "description": "The city or location."
        },
        "postalCode": {
          "type": "string",
          "description": "The postal code."
        },
        "contact": {
          "type": "string",
          "description": "Primary contact phone number."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The customer's email address."
        },
        "nrt": {
          "type": "string",
          "description": "The tax registration number (NRT/NIF) of the customer."
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a construction project or work site (obra).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string", "description": "The name of the project." },
        "customerId": { "type": "string", "description": "ID of the customer this project belongs to." },
        "customerName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "finished"], "description": "Status of the work." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "customerId", "status"]
    },
    "Article": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Article",
      "type": "object",
      "description": "Represents a master item/material in the catalog.",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "unitPrice": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "description", "unitPrice"]
    },
    "ServiceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ServiceRecord",
      "type": "object",
      "description": "Represents a service record for an employee.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the service record."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee."
        },
        "customerId": {
          "type": "string",
          "description": "Reference to Customer."
        },
        "customerName": {
            "type": "string",
            "description": "Denormalized customer name for quick display."
        },
        "projectName": {
          "type": "string",
          "description": "Name of the construction project or work site."
        },
        "projectId": {
          "type": "string",
          "description": "ID of the linked project."
        },
        "arrivalDateTime": {
          "type": "string",
          "description": "Date and time of arrival for the service.",
          "format": "date-time"
        },
        "departureDateTime": {
          "type": "string",
          "description": "Date and time of departure for the service.",
          "format": "date-time"
        },
        "description": {
          "type": "string",
          "description": "Description of the service performed."
        },
        "pendingTasks": {
          "type": "string",
          "description": "Description of pending tasks for the service."
        },
        "serviceHourlyRate": {
          "type": "number",
          "description": "The specific hourly rate for this service."
        },
        "media": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["image", "video"] },
              "dataUrl": { "type": "string", "format": "uri" }
            },
            "required": ["type", "dataUrl"]
          }
        },
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "quantity": { "type": "number" },
              "unitPrice": { "type": "number" },
              "imageDataUrl": { "type": "string", "format": "uri" }
            }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "employeeId",
        "arrivalDateTime",
        "departureDateTime",
        "description"
      ]
    },
     "Albaran": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Albaran",
      "type": "object",
      "description": "Represents a generated albarà.",
      "properties": {
        "id": { "type": "string" },
        "albaranNumber": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "projectName": { "type": "string" },
        "serviceRecordIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "totalAmount": { "type": "number" },
        "status": {
            "type": "string",
            "enum": ["pendent", "facturat", "arxivat"]
        }
      },
      "required": ["id", "albaranNumber", "createdAt", "projectName", "serviceRecordIds", "totalAmount", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": { "$ref": "#/backend/entities/Employee" },
          "description": "Stores employee profiles.",
          "params": [{ "name": "employeeId" }]
        }
      },
      {
        "path": "/employees/{employeeId}/serviceRecords/{serviceRecordId}",
        "definition": {
          "entityName": "ServiceRecord",
          "schema": { "$ref": "#/backend/entities/ServiceRecord" },
          "description": "Stores service records.",
          "params": [{ "name": "employeeId" }, { "name": "serviceRecordId" }]
        }
      },
      {
        "path": "/customers/{customerId}",
        "definition": {
          "entityName": "Customer",
          "schema": { "$ref": "#/backend/entities/Customer" },
          "description": "Stores customer profiles.",
          "params": [{ "name": "customerId" }]
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": { "$ref": "#/backend/entities/Project" },
          "description": "Stores projects.",
          "params": [{ "name": "projectId" }]
        }
      },
      {
        "path": "/articles/{articleId}",
        "definition": {
          "entityName": "Article",
          "schema": { "$ref": "#/backend/entities/Article" },
          "description": "Master list of articles/materials.",
          "params": [{ "name": "articleId" }]
        }
      },
      {
        "path": "/albarans/{albaranId}",
        "definition": {
            "entityName": "Albaran",
            "schema": { "$ref": "#/backend/entities/Albaran" },
            "description": "Stores generated albaràs.",
            "params": [{ "name": "albaranId" }]
        }
      },
      {
        "path": "/quotes/{quoteId}",
        "definition": {
            "entityName": "Quote",
            "schema": { "$ref": "#/backend/entities/Quote" },
            "description": "Stores generated quotes.",
            "params": [{ "name": "quoteId" }]
        }
      },
       {
        "path": "/invoices/{invoiceId}",
        "definition": {
            "entityName": "Invoice",
            "schema": { "$ref": "#/backend/entities/Invoice" },
            "description": "Stores generated invoices.",
            "params": [{ "name": "invoiceId" }]
        }
      },
       {
        "path": "/receipts/{receiptId}",
        "definition": {
            "entityName": "Receipt",
            "schema": { "$ref": "#/backend/entities/Receipt" },
            "description": "Stores generated receipts.",
            "params": [{ "name": "receiptId" }]
        }
      }
    ]
  }
}
